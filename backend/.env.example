# Copy to backend/.env and fill in real values. Never commit backend/.env.

# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_DB_CONN_MAX_AGE=60

# PostgreSQL (local dev; docker-compose uses pgbouncer on 6432)
POSTGRES_DB=art_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Optional legacy URL (not required if POSTGRES_* are set)
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/art_platform

# CORS (comma-separated; Vite default origin)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend URL (links in emails, if used)
FRONTEND_URL=http://localhost:5173

# OpenAI (associations, phrases, palettes, admin model list)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_RATE_LIMIT_RETRIES=4
OPENAI_MODELS_LIST_CACHE_SEC=300

# Email: console backend prints codes to terminal (good for local dev)
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DJANGO_DEFAULT_FROM_EMAIL=no-reply@art.local
DJANGO_EMAIL_TIMEOUT=5

# SMTP example (single provider)
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DJANGO_EMAIL_HOST=smtp.example.com
# DJANGO_EMAIL_PORT=587
# DJANGO_EMAIL_HOST_USER=
# DJANGO_EMAIL_HOST_PASSWORD=
# DJANGO_EMAIL_USE_TLS=1
# DJANGO_EMAIL_USE_SSL=0

# Multi-provider profiles (comma-separated: gmail,mailru,yandex)
# DJANGO_EMAIL_PROFILES=yandex
# DJANGO_EMAIL_YANDEX_DEFAULT_FROM_EMAIL=
# DJANGO_EMAIL_YANDEX_HOST=smtp.yandex.ru
# DJANGO_EMAIL_YANDEX_PORT=465
# DJANGO_EMAIL_YANDEX_USE_TLS=0
# DJANGO_EMAIL_YANDEX_USE_SSL=1
# DJANGO_EMAIL_YANDEX_HOST_USER=
# DJANGO_EMAIL_YANDEX_HOST_PASSWORD=
